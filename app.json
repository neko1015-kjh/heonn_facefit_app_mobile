{
  "expo": {
    "name": "FaceFit",
    "slug": "facefit",
    "version": "1.0.0",
    "scheme": "facefit",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.heonn.facefit",
      "buildNumber": "18",
      "infoPlist": {
        "NSCameraUsageDescription": "얼굴 분석 사진을 촬영하기 위해 카메라를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "얼굴 분석에 사용할 사진을 선택하기 위해 사진 보관함에 접근합니다."
      }
    },
    "android": {
      "package": "com.heonn.facefit",
      "versionCode": 18,
      "adaptiveIcon": {
        "backgroundColor": "#D8AE58",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1313a13c-b9e0-4a04-be19-54cd5f227dea"
      }
    },
    "owner": "neko1015",
    "plugins": [
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "얼굴 분석 사진을 촬영하기 위해 카메라를 사용합니다."
        }
      ]
    ]
  }
}
